# Required. Create a fine-grained GitHub token with repository contents
# read/write access for the repository that receives data updates.
GITHUB_TOKEN=github_pat_replace_me

# Optional tuning for the Raspberry Pi runner. The defaults are conservative
# enough for an hourly timer on a Raspberry Pi.
MAX_PLUGINS=500
MAX_RUNTIME_MINUTES=25
RATE_LIMIT_FLOOR=100
BRANCH=main

# Optional commit identity for metadata updates.
GIT_COMMITTER_NAME=lemons-pi
GIT_COMMITTER_EMAIL=lemons.pi22@gmail.com
